{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "bea-uptime",
	"compatibility_date": "2026-03-23",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./worker-api/src/index.ts",
	"d1_databases": [
		{
			"binding": "DB",
			// Replace with the D1 database id from your own Cloudflare account before remote deploys.
			"database_id": "bf6ada5c-6d7c-43f5-a9cf-e7d02128e315",
			"migrations_dir": "./worker-api/migrations"
		}
	],	
	"vars": {
		// Replace with a random string for authentication
		"AUTH_ROOT_SECRET": "change-me-to-a-random-string",
		"ALERT_TO_EMAIL": "",
		"ALERT_FROM_EMAIL": "",
		"SERVICE_LIMIT": "10",
		"DEFAULT_TIMEOUT_MS": "8000",
		"INCIDENT_FAILURE_THRESHOLD": "2",
		"INCIDENT_RETENTION_DAYS": "730"
	},
	"assets": {
		"directory": "./dist/web-vue",
		"binding": "ASSETS",
		"not_found_handling": "404-page",
		"html_handling": "none",
		"run_worker_first": true
	},
	"triggers": {
		"crons": [
			"* * * * *",
			"17 3 * * *"
		]
	},
	"send_email": [
		{
			"name": "SEND_EMAIL"
		}
	],
	"observability": {
		"enabled": false,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	}
}
